# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173,https://over-tech-psi.vercel.app

# ─── Database ──────────────────────────────────────────────────────────────────
# Local dev: in-memory MongoDB starts automatically.
# Production (Render): set MongoDB Atlas connection string in Render dashboard.
MONGODB_URI=mongodb://127.0.0.1:27017/overtech

# ─── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

# ─── Admin & Security ──────────────────────────────────────────────────────────
ADMIN_PASSWORD=your_secure_admin_password

# ================================
# JWT Authentication
# ================================
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
