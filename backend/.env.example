# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=https://your-frontend-app.vercel.app

# ─── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/overtech?retryWrites=true&w=majority

# ─── Razorpay ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_* for test mode, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
