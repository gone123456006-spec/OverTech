# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Database ──────────────────────────────────────────────────────────────────
# Local dev: in-memory MongoDB starts automatically.
# Production (Render): set MongoDB Atlas connection string in Render dashboard.
MONGODB_URI=mongodb://127.0.0.1:27017/overtech

# ─── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
