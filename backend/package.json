{
    "name": "ecommerce-backend",
    "version": "1.0.0",
    "description": "Backend for Ecommerce App",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "predev": "powershell -Command \"Get-NetTCPConnection -LocalPort 5000 -State Listen -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }; exit 0\"",
        "dev": "node --watch server.js",
        "seed-stores": "node scripts/seedStores.js"
    },
    "dependencies": {
        "axios": "^1.13.6",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^8.2.1",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.3.4",
        "morgan": "^1.10.0",
        "razorpay": "^2.9.6"
    }
}